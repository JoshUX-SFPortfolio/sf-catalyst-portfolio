<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Records CSAT and NPS survey responses linked to Cases and Contacts. CSAT scores feed the Account Health Score calculation. Core layer object — present in all verticals. Do not modify from a vertical branch.</description>
    <enableActivities>false</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>false</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>false</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <label>Feedback Survey</label>
    <nameField>
        <displayFormat>SURVEY-{00000}</displayFormat>
        <label>Survey Reference</label>
        <trackHistory>false</trackHistory>
        <type>AutoNumber</type>
    </nameField>
    <pluralLabel>Feedback Surveys</pluralLabel>
    <searchLayouts/>
    <sharingModel>Private</sharingModel>
</CustomObject>
